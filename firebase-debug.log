[debug] [2026-06-03T11:39:29.990Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/digitalizacion-tsinge-fusion/rulesets {"name":"projects/digitalizacion-tsinge-fusion/rulesets/3441c16e-2d60-4a40-b991-39e8a921a215","source":{"files":[{"content":"rules_version = '2';\r\n\r\n// ============================================================\r\n// Tsinghe Cocina Fusión - Reglas de seguridad Firestore\r\n// Roles: \"admin\" | \"comensal\"\r\n// ============================================================\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // ── Funcion auxiliar: comprueba si el usuario logueado es admin ──────\r\n    function isAdmin() {\r\n      return request.auth != null &&\r\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == \"admin\";\r\n    }\r\n\r\n    // ── Funcion auxiliar: comprueba si el usuario esta logueado ──────────\r\n    function isLoggedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // ── Funcion auxiliar: comprueba si el uid del doc es el usuario actual\r\n    function isOwner(uid) {\r\n      return request.auth != null && request.auth.uid == uid;\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // USERS\r\n    // Crear: solo el propio usuario al registrarse o un admin\r\n    // Leer:  el propio usuario o un admin\r\n    // Editar: el propio usuario o un admin (con validación de PIN si lo cambia)\r\n    // Borrar: solo admin\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /users/{uid} {\r\n      allow create: if isOwner(uid) || isAdmin();\r\n      allow read:   if isOwner(uid) || isAdmin();\r\n      allow update: if (isOwner(uid) || isAdmin()) &&\r\n                       // Si se actualiza adminPin, debe ser string de 4 dígitos\r\n                       (!request.resource.data.keys().hasAny(['adminPin']) ||\r\n                        request.resource.data.adminPin is string &&\r\n                        request.resource.data.adminPin.size() == 4 &&\r\n                        request.resource.data.adminPin.matches('[0-9]{4}'));\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // MENUS\r\n    // Leer: publico (cualquiera, sin login)\r\n    // Escribir: solo admin\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /menus/{menuId} {\r\n      allow read:   if true;\r\n      allow create,\r\n            update,\r\n            delete: if isAdmin();\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // OFFERS\r\n    // Leer: publico\r\n    // Escribir: solo admin\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /offers/{offerId} {\r\n      allow read:   if true;\r\n      allow create,\r\n            update,\r\n            delete: if isAdmin();\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // TABLES\r\n    // Leer: publico (para mostrar números de mesa en reservas)\r\n    // Escribir: solo admin\r\n    // Fusión: solo admins, máximo 4+ comensales, con PIN de 4 dígitos\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /appSettings/{settingId} {\n      allow read: if isLoggedIn();\n      allow create,\n            update,\n            delete: if isAdmin();\n    }\n\n    match /tables/{tableId} {\n      allow read:   if true;\r\n      \r\n      allow create: if isAdmin() && \r\n                       request.resource.data.capacity is number &&\r\n                       request.resource.data.capacity > 0 &&\r\n                       request.resource.data.tableNumber is number;\r\n      \r\n      allow update: if isAdmin() &&\r\n                       // Validar cambios de fusión\r\n                       (!request.resource.data.keys().hasAny(['mergedWith', 'fusedWith']) ||\r\n                        request.resource.data.get('mergedWith', []) is list) &&\r\n                       // Validar que los campos básicos sean válidos\r\n                       (request.resource.data.capacity is number &&\r\n                        request.resource.data.tableNumber is number);\r\n      \r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // RESERVATIONS\r\n    // Leer: el propietario de la reserva o un admin\r\n    // Crear: cualquier usuario logueado o admin\r\n    // Editar: el propietario o admin\r\n    // Borrar: el propietario o admin\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /reservations/{reservationId} {\r\n      allow read:   if isLoggedIn() &&\r\n                       (resource.data.userId == request.auth.uid || isAdmin());\r\n\r\n      allow create: if isLoggedIn() &&\r\n                       (request.resource.data.userId == request.auth.uid || isAdmin());\r\n\r\n      allow update: if isLoggedIn() &&\r\n                       (resource.data.userId == request.auth.uid || isAdmin());\r\n\r\n      allow delete: if isLoggedIn() &&\r\n                       (resource.data.userId == request.auth.uid || isAdmin());\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // RESERVATION CONFIRMATIONS\r\n    // Crear: cualquier usuario logueado (al confirmar reserva)\r\n    // Leer: el propietario del email o admin\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /reservationConfirmations/{confirmationId} {\r\n      allow read:   if isLoggedIn();\r\n      allow create: if isLoggedIn();\r\n      allow update: if isLoggedIn();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // PASSWORD RESETS\r\n    // Crear: cualquier usuario (solicitar reset)\r\n    // Leer/Actualizar: cualquier usuario (el token se valida en el servidor)\r\n    // Borrar: cualquier usuario (después de usar el token)\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /passwordResets/{email} {\r\n      allow read:   if true;\r\n      allow create: if true;\r\n      allow update: if true;\r\n      allow delete: if true;\r\n    }\r\n\r\n    // ════════════════════════════════════════════════════════════════════\r\n    // Todo lo demas: denegado por defecto\r\n    // ════════════════════════════════════════════════════════════════════\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-03T11:39:31.002447Z","metadata":{"services":["cloud.firestore"]}}
